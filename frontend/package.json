{
  "name": "kita-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "KITA web frontend (React + TypeScript + Vite): login page + auth context + protected routing shell.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run",
    "gen:api": "openapi-typescript ../contracts/openapi.yaml -o src/api/schema.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-tabs": "^1.1.18",
    "lucide-react": "^0.400.0",
    "openapi-fetch": "^0.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.9.0",
    "jsdom": "^25.0.0",
    "openapi-typescript": "^7.3.0",
    "postcss": "^8.5.20",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
