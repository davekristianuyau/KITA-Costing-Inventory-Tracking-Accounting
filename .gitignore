# --- Node / frontend ---
node_modules/
frontend/dist/
frontend/build/
*.log
npm-debug.log*

# --- Java / Gradle (backend) ---
.gradle/
**/build/
**/bin/
*.class
*.jar
!**/gradle/wrapper/gradle-wrapper.jar

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Terraform ---
**/.terraform/
*.tfstate
*.tfstate.*
# keep .terraform.lock.hcl tracked (pins provider versions)

# --- Docker ---
# (no build artifacts tracked)

# --- IDE / OS ---
.idea/
*.iml
.DS_Store
Thumbs.db
*.swp
# .vscode/ is intentionally tracked so shared editor settings sync across machines
