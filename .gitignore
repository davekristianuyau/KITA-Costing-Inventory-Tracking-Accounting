# --- Node / frontend ---
node_modules/
frontend/dist/
frontend/build/
*.log
npm-debug.log*

# --- Java / Gradle (backend) ---
.gradle/
**/build/
**/bin/
*.class
*.jar
!**/gradle/wrapper/gradle-wrapper.jar

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Terraform ---
**/.terraform/
*.tfstate
*.tfstate.*
# keep .terraform.lock.hcl tracked (pins provider versions)

# --- Deploy runtime state (local, per-machine) ---
infra/terraform/.last-good/    # last-good Release Set snapshots (auto-rollback)
infra/terraform/.deployments/  # deployment audit logs (FR-016)

# --- Docker ---
# (no build artifacts tracked)
docker-compose.override.yml    # local-only host-port overrides (keep the .example tracked)
!docker-compose.override.yml.example

# --- IDE / OS ---
.idea/
*.iml
.DS_Store
Thumbs.db
*.swp
# .vscode/ is intentionally tracked so shared editor settings sync across machines
