# Example environment configuration for the local containerized stack (008-docker-cache-database).
# Copy to `.env` and adjust. NEVER commit a real `.env` (see .gitignore).
# Production supplies these same keys from its per-environment secret store ({client}-{env}).

# --- Database (PostgreSQL 16) — one database, one schema per service ---
POSTGRES_DB=kita
POSTGRES_USER=kita
POSTGRES_PASSWORD=change-me
DATABASE_USER=kita
DATABASE_PASSWORD=change-me
# Each service connects to the same DB but its own schema (currentSchema=<svc>,public):
OPERATIONS_DATABASE_URL=jdbc:postgresql://postgres:5432/kita?currentSchema=operations,public
HR_DATABASE_URL=jdbc:postgresql://postgres:5432/kita?currentSchema=hr,public
CRM_DATABASE_URL=jdbc:postgresql://postgres:5432/kita?currentSchema=crm,public
PROCUREMENT_DATABASE_URL=jdbc:postgresql://postgres:5432/kita?currentSchema=procurement,public
WORKFLOW_DATABASE_URL=jdbc:postgresql://postgres:5432/kita?currentSchema=workflow,public

# --- Cache (Redis 7.4) — shared, non-authoritative ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Service wiring (gateway routes) ---
GATEWAY_URL=http://gateway:8081
OPERATIONS_SERVICE_URL=http://operations-service:8083
HR_SERVICE_URL=http://hr-service:8085
CRM_SERVICE_URL=http://crm-service:8086
PROCUREMENT_SERVICE_URL=http://procurement-service:8087
WORKFLOW_SERVICE_URL=http://workflow-service:8088

# --- Identity & session (009-client-login-deploy-sim) ---
# Token keys — base64. When BLANK, identity generates EPHEMERAL keys (dev only). Production AND the edge
# must share the SAME public/enc keys (identity signs with the private key; edge/backends verify+decrypt).
# Generate: openssl genpkey / rand — see specs/009-client-login-deploy-sim/quickstart.md.
IDENTITY_JWT_PRIVATE_KEY=       # base64 PKCS8 RSA private (signing)
IDENTITY_JWT_PUBLIC_KEY=        # base64 X509 RSA public (verify)
IDENTITY_JWT_ENC_KEY=          # base64 32-byte AES (JWE encrypt/decrypt)
IDENTITY_JWT_TTL_MINUTES=90     # forced re-auth window
IDENTITY_COOKIE_SECURE=false    # true in production (HTTPS)
IDENTITY_SEED_PASSWORD=change-me-demo   # demo users' password (dev seed only)
IDENTITY_DATABASE_URL=jdbc:postgresql://postgres:5432/kita?currentSchema=identity,public
