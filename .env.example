# Example environment configuration for local development (Docker Compose).
# Copy to `.env` and adjust. NEVER commit a real `.env` (see .gitignore).
# SCAFFOLDING PLACEHOLDER — values are illustrative; services are implemented later.

# --- Database (PostgreSQL) ---
DATABASE_URL=jdbc:postgresql://postgres:5432/kita
DATABASE_USER=kita
DATABASE_PASSWORD=change-me
POSTGRES_DB=kita
POSTGRES_USER=kita
POSTGRES_PASSWORD=change-me

# --- Service wiring ---
GATEWAY_URL=http://gateway:8081
REFERENCE_SERVICE_URL=http://reference-service:8082
